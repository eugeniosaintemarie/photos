{
  "input": "./gallery",
  "output": "./build_output",
  "title": "∃camera",
  "sort-albums-by": "title",
  "sort-media-by": "filename",
  "download-photos": "copy",
  "cleanup": true,
  "theme": "cards",
  "theme-style": "./custom.css",
  "footer": "<a data-repo=\"\" href=\"#\" target=\"_blank\" rel=\"noopener\">∃ugenio © 2019</a>\n<script>\n  (() => {\n    const siteBaseURL = \"https://eugeniosaintemarie.github.io\".replace(/\/$/, \"\");\n    const buildRepoURL = (repoName, query = \"\") => {\n      const url = new URL(`${repoName ? `${repoName}/` : \"/\"}`, `${siteBaseURL}/`);\n      if (query) {\n        url.search = query.startsWith(\"?\") ? query : `?${query}`;\n      }\n      return url.toString();\n    };\n    document.querySelectorAll(\"[data-repo]\").forEach((link) => {\n      const repoName = link.dataset.repo;\n      if (repoName === undefined) {\n        return;\n      }\n      link.href = buildRepoURL(repoName, link.dataset.query || \"\");\n    });\n  })();\n</script>",
  "usage-stats": false
}
