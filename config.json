{
  "input": "./gallery",
  "output": "./build_output",
  "title": "∃camera",
  "sort-albums-by": "title",
  "sort-media-by": "filename",
  "download-photos": "copy",
  "cleanup": true,
  "theme": "cards",
  "theme-style": "./custom.css",
  "footer": "<a data-repo=\"\" href=\"/\" target=\"_blank\" rel=\"noopener\">∃ugenio © 2019</a>\n<script>\n  (() => {\n    const defaultBaseURL = window.location.origin.replace(/\\/$/, \"\");\n    const configURL = new URL(\"/config.json\", window.location.origin).toString();\n    const buildRepoURL = (baseURL, repoName = \"\", query = \"\") => {\n      const url = new URL(repoName ? `${repoName}/` : \"/\", baseURL.endsWith(\"/\") ? baseURL : `${baseURL}/`);\n      if (query) {\n        const normalizedQuery = query.startsWith(\"?\") ? query.slice(1) : query;\n        new URLSearchParams(normalizedQuery).forEach((value, key) => {\n          url.searchParams.set(key, value);\n        });\n      }\n      return url.toString();\n    };\n    const updateLinks = (baseURL) => {\n      document.querySelectorAll(\"[data-repo]\").forEach((link) => {\n        const repoName = link.dataset.repo;\n        if (repoName === undefined) {\n          return;\n        }\n        link.href = buildRepoURL(baseURL, repoName, link.dataset.query || \"\");\n      });\n    };\n    updateLinks(defaultBaseURL);\n    fetch(configURL)\n      .then((res) => (res.ok ? res.json() : null))\n      .then((config) => {\n        if (!config?.baseURL) {\n          return;\n        }\n        updateLinks(config.baseURL);\n      })\n      .catch(() => {});\n  })();\n</script>",
  "usage-stats": false
}